<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <ApplicationIcon />
    <AssemblyName>SpeechPrint</AssemblyName>
    <RootNamespace>SpeechPrint</RootNamespace>
    <Version>0.3.0</Version>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <PublishSingleFile>true</PublishSingleFile>
    <SelfContained>true</SelfContained>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
  </PropertyGroup>

  <ItemGroup>
    <EmbeddedResource Include="..\scripts\install_package.ps1" Link="Resources\install_package.ps1" />
    <EmbeddedResource Include="..\scripts\packages.psd1" Link="Resources\packages.psd1" />
    <EmbeddedResource Include="..\..\templates\**\*" Link="Resources\templates\%(RecursiveDir)%(Filename)%(Extension)" />
  </ItemGroup>

</Project>
