    item [8]:
        class = "IntervalTier"
        name = "h_ft@TA"
        xmin = 0.0
        xmax = 162.685
        intervals: size = 73
        intervals [1]:
            xmin = 0.0
            xmax = 4.726
            text = "<p:>"
        intervals [2]:
            xmin = 4.726
            xmax = 8.129
            text = "my name is Tukun Apia"
        intervals [3]:
            xmin = 8.129
            xmax = 9.29
            text = "<p:>"
        intervals [4]:
            xmin = 9.29
            xmax = 13.184
            text = "I want to tell a story"
        intervals [5]:
            xmin = 13.184
            xmax = 15.349
            text = "<p:>"
        intervals [6]:
            xmin = 15.349
            xmax = 15.929
            text = "****"
        intervals [7]:
            xmin = 15.929
            xmax = 16.679
            text = "<p:>"
        intervals [8]:
            xmin = 16.679
            xmax = 22.494
            text = "this story is about a woman and her husband"
        intervals [9]:
            xmin = 22.494
            xmax = 23.25
            text = "<p:>"
        intervals [10]:
            xmin = 23.25
            xmax = 27.873
            text = "the two lived on, his woman was pregnant with a child"
        intervals [11]:
            xmin = 27.873
            xmax = 28.842
            text = "<p:>"
        intervals [12]:
            xmin = 28.842
            xmax = 31.292
            text = "so, she gave birth to her baby"
        intervals [13]:
            xmin = 31.292
            xmax = 31.904
            text = "<p:>"
        intervals [14]:
            xmin = 31.904
            xmax = 36.125
            text = "in the hospital, the baby was a boy"
        intervals [15]:
            xmin = 36.125
            xmax = 37.712
            text = "<p:>"
        intervals [16]:
            xmin = 37.712
            xmax = 40.424
            text = "when she came back, the two lived on"
        intervals [17]:
            xmin = 40.424
            xmax = 41.3
            text = "<p:>"
        intervals [18]:
            xmin = 41.3
            xmax = 44.826
            text = "so, the child grew, his mother died"
        intervals [19]:
            xmin = 44.826
            xmax = 46.02
            text = "<p:>"
        intervals [20]:
            xmin = 46.02
            xmax = 50.47
            text = "his mother died, the small boy with his father only stayed"
        intervals [21]:
            xmin = 50.47
            xmax = 51.13
            text = "<p:>"
        intervals [22]:
            xmin = 51.13
            xmax = 52.668
            text = "with his father, the two stayed"
        intervals [23]:
            xmin = 52.668
            xmax = 53.677
            text = "<p:>"
        intervals [24]:
            xmin = 53.677
            xmax = 54.604
            text = "the two lived on"
        intervals [25]:
            xmin = 54.604
            xmax = 55.05
            text = "<p:>"
        intervals [26]:
            xmin = 55.05
            xmax = 60.342
            text = "his father wanted to go drink kava"
        intervals [27]:
            xmin = 60.342
            xmax = 61.73
            text = "<p:>"
        intervals [28]:
            xmin = 61.73
            xmax = 66.415
            text = "when he went, he carried his chiild, the two stayed"
        intervals [29]:
            xmin = 66.415
            xmax = 67.15
            text = "<p:>"
        intervals [30]:
            xmin = 67.15
            xmax = 74.461
            text = "when he drank kava, he put his child under a tree"
        intervals [31]:
            xmin = 74.461
            xmax = 75.85
            text = "<p:>"
        intervals [32]:
            xmin = 75.85
            xmax = 78.02
            text = "he stayed, the child slept"
        intervals [33]:
            xmin = 78.02
            xmax = 79.04
            text = "<p:>"
        intervals [34]:
            xmin = 79.04
            xmax = 86.967
            text = "the father drank kava, and so he forgot about the child"
        intervals [35]:
            xmin = 86.967
            xmax = 88.03
            text = "<p:>"
        intervals [36]:
            xmin = 88.03
            xmax = 92.644
            text = "when the child was asleep, a demon came and took it"
        intervals [37]:
            xmin = 92.644
            xmax = 93.03
            text = "<p:>"
        intervals [38]:
            xmin = 93.03
            xmax = 94.831
            text = "he carried the child, the two went away"
        intervals [39]:
            xmin = 94.831
            xmax = 96.1
            text = "<p:>"
        intervals [40]:
            xmin = 96.1
            xmax = 99.6
            text = "the two went, he carried him, he stayed on top of his shoulder"
        intervals [41]:
            xmin = 99.6
            xmax = 100.68
            text = "<p:>"
        intervals [42]:
            xmin = 100.68
            xmax = 106.337
            text = "the two followed the road, the child saw a branch across the road"
        intervals [43]:
            xmin = 106.337
            xmax = 107.5
            text = "<p:>"
        intervals [44]:
            xmin = 107.5
            xmax = 112.196
            text = "the child jumped, grasping the branch, and went up and stayed on top"
        intervals [45]:
            xmin = 112.196
            xmax = 112.98
            text = "<p:>"
        intervals [46]:
            xmin = 112.98
            xmax = 114.126
            text = "the demon went on"
        intervals [47]:
            xmin = 114.126
            xmax = 114.56
            text = "<p:>"
        intervals [48]:
            xmin = 114.56
            xmax = 117.705
            text = "he thought that the child was sitting on his shoulder"
        intervals [49]:
            xmin = 117.705
            xmax = 119.27
            text = "<p:>"
        intervals [50]:
            xmin = 119.27
            xmax = 125.585
            text = "the child, his father, when he finished drinking kava, he thought about his child"
        intervals [51]:
            xmin = 125.585
            xmax = 126.14
            text = "<p:>"
        intervals [52]:
            xmin = 126.14
            xmax = 129.754
            text = "he went and looked for his child, but his child was lost"
        intervals [53]:
            xmin = 129.754
            xmax = 131.243
            text = "<p:>"
        intervals [54]:
            xmin = 131.243
            xmax = 131.324
            text = "****"
        intervals [55]:
            xmin = 131.324
            xmax = 132.261
            text = "he kept looking out for him"
        intervals [56]:
            xmin = 132.261
            xmax = 133.08
            text = "<p:>"
        intervals [57]:
            xmin = 133.08
            xmax = 133.234
            text = "****"
        intervals [58]:
            xmin = 133.234
            xmax = 134.825
            text = "he followed the road, he went on"
        intervals [59]:
            xmin = 134.825
            xmax = 135.14
            text = "<p:>"
        intervals [60]:
            xmin = 135.14
            xmax = 137.914
            text = "he saw that his boy stayed on the branch"
        intervals [61]:
            xmin = 137.914
            xmax = 138.93
            text = "<p:>"
        intervals [62]:
            xmin = 138.93
            xmax = 140.544
            text = "he took his boy from the tree"
        intervals [63]:
            xmin = 140.544
            xmax = 141.2
            text = "<p:>"
        intervals [64]:
            xmin = 141.2
            xmax = 143.349
            text = "he carried him and came, the two went home"
        intervals [65]:
            xmin = 143.349
            xmax = 144.387
            text = "<p:>"
        intervals [66]:
            xmin = 144.387
            xmax = 147.631
            text = "the demon came and looked for the child, he did not see him"
        intervals [67]:
            xmin = 147.631
            xmax = 149.238
            text = "<p:>"
        intervals [68]:
            xmin = 149.238
            xmax = 152.74
            text = "the child, his father carried him, the two went, finish"
        intervals [69]:
            xmin = 152.74
            xmax = 153.59
            text = "<p:>"
        intervals [70]:
            xmin = 153.59
            xmax = 157.987
            text = "this is the my short story that I want to tell"
        intervals [71]:
            xmin = 157.987
            xmax = 158.996
            text = "<p:>"
        intervals [72]:
            xmin = 158.996
            xmax = 159.918
            text = "thank you very much"
        intervals [73]:
            xmin = 159.918
            xmax = 162.685
            text = "<p:>"
