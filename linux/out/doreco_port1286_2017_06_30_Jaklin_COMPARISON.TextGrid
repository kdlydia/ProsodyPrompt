            xmax = 22.494
            text = "punen          kiye      mu     usilii vaven soo    són     san       yaapuo"
        intervals [9]:
            xmin = 22.494
            xmax = 23.25
            text = "<p:>"
        intervals [10]:
            xmin = 23.25
            xmax = 27.873
            text = "kolom     du       van,    san       vanmoro mo sógó        saloo     waawaa soo"
        intervals [11]:
            xmin = 27.873
            xmax = 28.842
            text = "<p:>"
        intervals [12]:
            xmin = 28.842
            xmax = 31.292
            text = "mwe van, mwi    lingi      san       waawaa"
        intervals [13]:
            xmin = 31.292
            xmax = 31.904
            text = "<p:>"
        intervals [14]:
            xmin = 31.904
            xmax = 36.125
            text = "pán  em           ne meseen, san       waawaa me e        timaleh man"
        intervals [15]:
            xmin = 36.125
            xmax = 37.712
            text = "<p:>"
        intervals [16]:
            xmin = 37.712
            xmax = 40.424
            text = "bili ke     mu     kuoli, me mee,     kolom     du"
        intervals [17]:
            xmin = 40.424
            xmax = 41.3
            text = "<p:>"
        intervals [18]:
            xmin = 41.3
            xmax = 44.826
            text = "van, timaleh me mee      mo     bo, san       naana me     met"
        intervals [19]:
            xmin = 44.826
            xmax = 46.02
            text = "<p:>"
        intervals [20]:
            xmin = 46.02
            xmax = 50.47
            text = "san       naana  me     met, timaleh man són     san       taati  gon   kolom     du"
        intervals [21]:
            xmin = 50.47
            xmax = 51.13
            text = "<p:>"
        intervals [22]:
            xmin = 51.13
            xmax = 52.668
            text = "són     teman             kolom     du"
        intervals [23]:
            xmin = 52.668
            xmax = 53.677
            text = "<p:>"
        intervals [24]:
            xmin = 53.677
            xmax = 54.604
            text = "kolom     du       van"
        intervals [25]:
            xmin = 54.604
            xmax = 55.05
            text = "<p:>"
        intervals [26]:
            xmin = 55.05
            xmax = 60.342
            text = "teman                       mo       longbini ka      be     van bi     mini  liibweyee"
        intervals [27]:
            xmin = 60.342
            xmax = 61.73
            text = "<p:>"
        intervals [28]:
            xmin = 61.73
            xmax = 66.415
            text = "bili ke     me van,    mwe    vehe  san       timaleh, kolom     du"
        intervals [29]:
