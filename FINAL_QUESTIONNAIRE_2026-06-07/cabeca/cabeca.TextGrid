    item [1]:
        class = "IntervalTier"
        name = "sentence"
        xmin = 0
        xmax = 81.82
        intervals: size = 49
        intervals [1]:
            xmin = 0.0
            xmax = 0.091
            text = ""
        intervals [2]:
            xmin = 0.091
            xmax = 4.2
            text = "Oso kalu je të yaba kiá-mĩ jinõ klötiö í ra"
        intervals [3]:
            xmin = 4.2
            xmax = 4.452
            text = ""
        intervals [4]:
            xmin = 4.452
            xmax = 5.708
            text = "Jeska í klötiá-mĩ"
        intervals [5]:
            xmin = 5.708
            xmax = 8.157
            text = "jie-wa të jes ka í të nãmã je wã köpö"
        intervals [6]:
            xmin = 8.157
            xmax = 8.886
            text = ""
        intervals [7]:
            xmin = 8.886
            xmax = 9.857
            text = "Nãmã nẽ ka ĩã keper"
        intervals [8]:
            xmin = 9.857
            xmax = 10.933
            text = ""
        intervals [9]:
            xmin = 10.933
            xmax = 14.404
            text = "Ñerö í wakwa mẽnẽũ-lo jeska maga kalwö kwã'-ite"
        intervals [10]:
            xmin = 14.404
            xmax = 14.748
            text = ""
        intervals [11]:
            xmin = 14.748
            xmax = 15.787
            text = "Kwã'sã' oso të"
        intervals [12]:
            xmin = 15.787
            xmax = 16.645
            text = ""
        intervals [13]:
            xmin = 16.645
            xmax = 17.745
            text = "Ñerö (m) yaba ĩã e-gla ã'-ite"
        intervals [14]:
            xmin = 17.745
            xmax = 25.373
            text = "Í wagi të e-gla gugá-wã begetsá-ite (eh) oso të e-gla kwã'u-mĩ tsagu wa Ñerö yaba të e-gla kwã'-nẽ tsagu wa í tsagu dlönã-sã' bá-ite plája"
        intervals [15]:
            xmin = 25.373
            xmax = 30.96
            text = "Ñerö tögapa oso kaga të sawak kete-gẽ yaba pakká-ite sawak kötö"
        intervals [16]:
            xmin = 30.96
            xmax = 31.317
            text = ""
        intervals [17]:
            xmin = 31.317
            xmax = 33.211
            text = "Yaba ka të í kete kal já-ite plája inga"
        intervals [18]:
            xmin = 33.211
            xmax = 33.487
            text = ""
        intervals [19]:
            xmin = 33.487
            xmax = 34.78
            text = "ka ĩã í ñákõnẽ-wã"
        intervals [20]:
            xmin = 34.78
            xmax = 34.962
            text = ""
        intervals [21]:
            xmin = 34.962
            xmax = 38.871
            text = "Ñẽ yaba të sawak kue-gẽ sawak ká-lo-mĩ í yiga"
        intervals [22]:
            xmin = 38.871
            xmax = 39.169
            text = ""
        intervals [23]:
            xmin = 39.169
            xmax = 43.187
            text = "Tögapa chomõli kwã'-ite chomõli tsá-ite chomõli katáwã oso të"
        intervals [24]:
            xmin = 43.187
            xmax = 44.46
            text = "Ta í kwö juã'-mĩ-ite (_)"
        intervals [25]:
            xmin = 44.46
            xmax = 44.932
            text = ""
        intervals [26]:
            xmin = 44.932
            xmax = 46.611
            text = "yaba wö ĩã wã'-gẽ chomõ mã'-ite ĩã e-gla"
        intervals [27]:
            xmin = 46.611
            xmax = 47.603
            text = "kea yaba të í jawã'-mĩ"
        intervals [28]:
            xmin = 47.603
            xmax = 47.824
            text = ""
        intervals [29]:
            xmin = 47.824
            xmax = 48.955
            text = "Yaba të chomõ ki kiá-nẽ ĩã (m)"
        intervals [30]:
            xmin = 48.955
            xmax = 49.333
            text = ""
        intervals [31]:
            xmin = 49.333
            xmax = 51.234
            text = "Ñerö chomõ mã'-ite ĩã e-gla (_)"
        intervals [32]:
            xmin = 51.234
            xmax = 51.563
            text = ""
        intervals [33]:
            xmin = 51.563
            xmax = 54.348
            text = "yaba ksenã'-ka (_) chomõ kajá-wã-mĩ yaba tã'ĩ"
        intervals [34]:
            xmin = 54.348
            xmax = 54.971
            text = ""
        intervals [35]:
            xmin = 54.971
            xmax = 59.554
            text = "Í wagi mẽnẽũ klötiö-gate tögapa yaba të í gugá-wã í mẽnẽ-ga í bata inga"
        intervals [36]:
            xmin = 59.554
            xmax = 62.586
            text = "Kea í (_) klötiö-gate í janã-mĩ Jeska nẽ í mẽnẽũ-lo diglö köga rö"
        intervals [37]:
            xmin = 62.586
            xmax = 62.759
            text = ""
        intervals [38]:
            xmin = 62.759
            xmax = 67.302
            text = "Jeska í mẽnẽũ-lo tsatkö diglö jãrga Oso jẽk báu-mĩ diglö jãrga yaba mẽnẽũ diglö jãrga"
        intervals [39]:
            xmin = 67.302
            xmax = 67.572
            text = ""
        intervals [40]:
            xmin = 67.572
            xmax = 69.133
            text = "tögapa í mẽnẽũ bata inga"
        intervals [41]:
            xmin = 69.133
            xmax = 71.589
            text = "Jeska yaba jẽk mã'wã bata inga kapagö í ra"
        intervals [42]:
            xmin = 71.589
            xmax = 71.663
            text = ""
        intervals [43]:
            xmin = 71.663
            xmax = 74.919
            text = "Je töinga nãmã dateũ buéwã kaljula nã"
        intervals [44]:
            xmin = 74.919
            xmax = 75.561
            text = ""
        intervals [45]:
            xmin = 75.561
            xmax = 76.337
            text = "Je të í sũẽ-gẽ"
        intervals [46]:
            xmin = 76.337
            xmax = 79.603
            text = "ñerö jie-wa ñãk bá-tula-mĩ diglö shãgã nẽ wagweta nẽ"
        intervals [47]:
            xmin = 79.603
            xmax = 79.917
            text = ""
        intervals [48]:
            xmin = 79.917
            xmax = 81.677
            text = "Ñerö jeska bönẽ í õnã'-wã"
        intervals [49]:
            xmin = 81.677
            xmax = 81.82
            text = ""
