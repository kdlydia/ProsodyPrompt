    item [3]:
        class = "IntervalTier"
        name = "translation"
        xmin = 0
        xmax = 81.82
        intervals: size = 49
        intervals [1]:
            xmin = 0.0
            xmax = 0.091
            text = ""
        intervals [2]:
            xmin = 0.091
            xmax = 4.2
            text = "‘There was a bear and it called a child to play, to dance with him."
        intervals [3]:
            xmin = 4.2
            xmax = 4.452
            text = ""
        intervals [4]:
            xmin = 4.452
            xmax = 5.708
            text = "They began to dance;"
        intervals [5]:
            xmin = 5.708
            xmax = 8.157
            text = "they there/they did not let the tiger sleep."
        intervals [6]:
            xmin = 8.157
            xmax = 8.886
            text = ""
        intervals [7]:
            xmin = 8.886
            xmax = 9.857
            text = "The tiger did not sleep."
        intervals [8]:
            xmin = 9.857
            xmax = 10.933
            text = ""
        intervals [9]:
            xmin = 10.933
            xmax = 14.404
            text = "So they went there, where on of them found the fruit."
        intervals [10]:
            xmin = 14.404
            xmax = 14.748
            text = ""
        intervals [11]:
            xmin = 14.748
            xmax = 15.787
            text = "the bear did,"
        intervals [12]:
            xmin = 15.787
            xmax = 16.645
            text = ""
        intervals [13]:
            xmin = 16.645
            xmax = 17.745
            text = "and gave one to the child."
        intervals [14]:
            xmin = 17.745
            xmax = 25.373
            text = "He took one and thought that the since the bear had broken the fruit open with its head, he could also do so, but his head hurt bang! And so he dropped it."
        intervals [15]:
            xmin = 25.373
            xmax = 30.96
            text = "Next daddy bear ate ants and asked the child to eat them too."
        intervals [16]:
            xmin = 30.96
            xmax = 31.317
            text = ""
        intervals [17]:
            xmin = 31.317
            xmax = 33.211
            text = "But the child would not eat them; so he dropped the stick on him bang!"
        intervals [18]:
            xmin = 33.211
            xmax = 33.487
            text = ""
        intervals [19]:
            xmin = 33.487
            xmax = 34.78
            text = "But it did not reach the child."
        intervals [20]:
            xmin = 34.78
            xmax = 34.962
            text = ""
        intervals [21]:
            xmin = 34.962
            xmax = 38.871
            text = "The child bit the ants and these ran away from him."
        intervals [22]:
            xmin = 38.871
            xmax = 39.169
            text = ""
        intervals [23]:
            xmin = 39.169
            xmax = 43.187
            text = "Next, they found ripe bananas, took them along and the bear ate them;"
        intervals [24]:
            xmin = 43.187
            xmax = 44.46
            text = "he threw the skin away;"
        intervals [25]:
            xmin = 44.46
            xmax = 44.932
            text = ""
        intervals [26]:
            xmin = 44.932
            xmax = 46.611
            text = "the child made a sad face, so the bear gave him a banana."
        intervals [27]:
            xmin = 46.611
            xmax = 47.603
            text = "But the child dropped it,"
        intervals [28]:
            xmin = 47.603
            xmax = 47.824
            text = ""
        intervals [29]:
            xmin = 47.824
            xmax = 48.955
            text = "and asked him for more."
        intervals [30]:
            xmin = 48.955
            xmax = 49.333
            text = ""
        intervals [31]:
            xmin = 49.333
            xmax = 51.234
            text = "So, he gave him another one."
        intervals [32]:
            xmin = 51.234
            xmax = 51.563
            text = ""
        intervals [33]:
            xmin = 51.563
            xmax = 54.348
            text = "The child was happy and brought more down."
        intervals [34]:
            xmin = 54.348
            xmax = 54.971
            text = ""
        intervals [35]:
            xmin = 54.971
            xmax = 59.554
            text = "Then he went away dancing and grabbed the bear and went on top of him;"
        intervals [36]:
            xmin = 59.554
            xmax = 62.586
            text = "so they danced and fell down all the way to the river bank."
        intervals [37]:
            xmin = 62.586
            xmax = 62.759
            text = ""
        intervals [38]:
            xmin = 62.759
            xmax = 67.302
            text = "They swam in the river; the bear jumped onto the river, the child went away in the river;"
        intervals [39]:
            xmin = 67.302
            xmax = 67.572
            text = ""
        intervals [40]:
            xmin = 67.572
            xmax = 69.133
            text = "next, he went on top of the bear."
        intervals [41]:
            xmin = 69.133
            xmax = 71.589
            text = "There the child talked to him."
        intervals [42]:
            xmin = 71.589
            xmax = 71.663
            text = ""
        intervals [43]:
            xmin = 71.663
            xmax = 74.919
            text = "Behind them came the tiger amid the branches;"
        intervals [44]:
            xmin = 74.919
            xmax = 75.561
            text = ""
        intervals [45]:
            xmin = 75.561
            xmax = 76.337
            text = "he saw them,"
        intervals [46]:
            xmin = 76.337
            xmax = 79.603
            text = "so they jumed back into the river again."
        intervals [47]:
            xmin = 79.603
            xmax = 79.917
            text = ""
        intervals [48]:
            xmin = 79.917
            xmax = 81.677
            text = "Then it just ended there.’"
        intervals [49]:
            xmin = 81.677
            xmax = 81.82
            text = ""
